# TamisTool — .gitignore
# hexbinedit.io

# -------------------------------------------------------------------
# Python build artifacts
# -------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
dist/
build/
*.egg-info/
*.egg
MANIFEST

# -------------------------------------------------------------------
# Virtual environments
# -------------------------------------------------------------------
.venv/
venv/
env/
.env/

# -------------------------------------------------------------------
# Environment files / secrets (never commit credentials)
# -------------------------------------------------------------------
.env
.env.*
*.env
# Allow the example file — it contains no real secrets
!.env.example

# -------------------------------------------------------------------
# Testing and coverage
# -------------------------------------------------------------------
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.tox/

# -------------------------------------------------------------------
# IDE and OS
# -------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# -------------------------------------------------------------------
# TamisTool-specific
# Note: ~/.tamis/ is a user-level config dir — NOT a repo artifact.
#       The entry below covers any .tamis/ that might appear in the
#       working directory (e.g. token cache during local dev/testing).
# -------------------------------------------------------------------
.tamis/

# SQLite database files — never commit client data
*.db

# Generated report output
reports/
