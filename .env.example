# TamisTool — environment variable reference
# Copy to .env and fill in your values. Never commit a populated .env file.
# hexbinedit.io

# ── Shared (both auth modes) ─────────────────────────────────────────────────
TAMIS_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TAMIS_CLUSTER_URI=https://<cluster>.kusto.windows.net
TAMIS_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Client Credentials mode (--auth client-credentials, default) ─────────────
TAMIS_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TAMIS_APP_SECRET=your-client-secret-here

# ── Device Code mode (--auth device-code) ────────────────────────────────────
# Uses TAMIS_TENANT_ID above. APP_ID may be the same or a separate registration.
# No secret is needed — the user authenticates interactively via browser.
TAMIS_DEVICE_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
